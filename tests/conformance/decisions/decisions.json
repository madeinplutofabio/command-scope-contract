        "agent_id": "a-1",
        "session_id": "s-1",
        "initiating_user": "u-1",
        "delegation_scope": "test"
      },
      "commands": [
        {
          "id": "cmd_1",
          "exec": {
            "argv": [
              "git",
              "status"
            ]
          },
          "cwd": "/workspace/repo",
          "read_paths": [
            "/workspace/repo/**"
          ],
          "write_paths": [],
          "network": "deny",
          "env_allow": [],
          "secret_refs": [],
          "timeout_sec": 10,
          "proposed_effect_type": "observe"
        }
      ],
      "risk_class": "low",
      "approval_mode": "policy_only",
      "justification": "check repo state"
    },
    "policy": {
      "policy_schema_version": "csc.policy.v0.1",
      "name": "dev-readonly",
      "allow_commands": [
        "git",
        "ls",
        "cat"
      ],
      "deny_argv_prefixes": [
        [
          "bash",
          "-lc"
